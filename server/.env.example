# ─── API Keys ───────────────────────────────────────────────
# חובה: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# אופציונלי: להרצת מודל שונה לכל סוכן
CONDUCTOR_MODEL=gemini-2.5-flash-live-preview
STORY_MODEL=gemini-2.5-flash-live-preview

# ─── Server ────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/tzumi.db

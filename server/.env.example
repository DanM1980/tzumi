# ─── API Keys ───────────────────────────────────────────────
# חובה: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# אופציונלי: להרצת מודל שונה לכל סוכן
# מודלי טקסט (REST API): gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
CONDUCTOR_MODEL=gemini-2.5-flash
STORY_MODEL=gemini-2.5-flash
FRIEND_MODEL=gemini-2.5-flash

# Gemini Live API — מודל קולי לדיבור בזמן אמת (WebSocket)
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# ─── Server ────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/tzumi.db
NODE_ENV=production

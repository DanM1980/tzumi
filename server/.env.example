# ─── API Keys ───────────────────────────────────────────────
# חובה: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# אופציונלי: להרצת מודל שונה לכל סוכן
CONDUCTOR_MODEL=gemini-2.0-flash
STORY_MODEL=gemini-2.0-flash
FRIEND_MODEL=gemini-2.0-flash

# Gemini Live API — מודל קולי לדיבור בזמן אמת
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# ─── Server ────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/tzumi.db
NODE_ENV=production
